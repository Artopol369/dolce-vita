---
import Base from "../layouts/Base.astro";
---
<Base title="404">
  <section class="max-w-2xl mx-auto px-5 py-32 text-center">
    <div class="font-display italic text-7xl md:text-9xl text-[color:var(--color-burgundy)]">404</div>
    <p class="mt-4 text-xl text-[color:var(--color-espresso)]/70">Diese Seite ist wie ein Napoleon — leider schon weg.</p>
    <p class="mt-1 text-xl text-[color:var(--color-espresso)]/70 font-display italic">Цієї сторінки немає, але торти є.</p>
    <a href="/" class="btn btn-primary mt-8 inline-flex">← Startseite / Головна</a>
  </section>
</Base>
