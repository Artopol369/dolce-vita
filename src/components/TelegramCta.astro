---
interface Props { label: string; variant?: "primary" | "ghost" }
const { label, variant = "primary" } = Astro.props;
const cls = variant === "primary" ? "btn btn-primary" : "btn btn-ghost";
---
<a href="https://t.me/la_dolce_gera" target="_blank" rel="noopener" class={cls}>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M22 3.5L2 11l6 2 2 7 4-4 5 5z" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linejoin="round"/>
  </svg>
  {label}
</a>
