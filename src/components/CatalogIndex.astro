---
import { getCollection } from "astro:content";
import { t, type Locale } from "../i18n/ui";
import CardTorte from "./CardTorte.astro";

interface Props { locale: Locale; collection: "tortes" | "sweets" }
const { locale, collection } = Astro.props;
const dict = t(locale);
const items = (await getCollection(collection)).sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
const sectionDict = collection === "tortes" ? dict.tortes : dict.sweets;
---
<section class="bg-gradient-to-b from-[color:var(--color-crema)] to-[color:var(--color-warm-white)]">
  <div class="max-w-6xl mx-auto px-5 lg:px-8 pt-14 pb-12 text-center">
    <div class="kicker">{collection === "tortes" ? "Signature collection" : "Small format"}</div>
    <h1 class="font-display italic text-5xl md:text-7xl text-[color:var(--color-burgundy)] mt-3">{sectionDict.page_title}</h1>
    <p class="mt-5 text-lg text-[color:var(--color-espresso)]/75 max-w-2xl mx-auto">{sectionDict.page_subtitle}</p>
    <p class="mt-3 text-sm text-[color:var(--color-espresso)]/60 max-w-2xl mx-auto">{sectionDict.intro}</p>
  </div>
</section>

<section class="py-12 md:py-16">
  <div class="max-w-6xl mx-auto px-5 lg:px-8">
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {items.map(item => <CardTorte item={item} locale={locale} collection={collection} />)}
    </div>
  </div>
</section>

<section class="py-12 mt-8 bg-[color:var(--color-burgundy)] text-[color:var(--color-warm-white)]">
  <div class="max-w-3xl mx-auto px-5 lg:px-8 text-center">
    <p class="font-display italic text-2xl md:text-3xl">{locale === "uk" ? "Готові замовити?" : "Bereit zu bestellen?"}</p>
    <p class="mt-3 text-[color:var(--color-warm-white)]/80 text-sm">{locale === "uk" ? "Напишіть нам у Telegram — обговоримо смаки, декор, дату." : "Schreibt uns auf Telegram — wir besprechen Geschmäcker, Dekor und Termin."}</p>
    <a href="https://t.me/la_dolce_gera" target="_blank" rel="noopener" class="inline-flex mt-6 items-center gap-2 bg-[color:var(--color-warm-white)] text-[color:var(--color-burgundy)] px-7 py-3.5 rounded-full font-medium hover:scale-105 transition">
      {dict.cta_telegram}
    </a>
  </div>
</section>
