---
import { getCollection } from "astro:content";
import { t, type Locale, localizePath } from "../i18n/ui";

interface Props { locale: Locale }
const { locale } = Astro.props;
const dict = t(locale);

const journal = (await getCollection("journal")).sort((a, b) => b.data.date.localeCompare(a.data.date));
const categories = dict.journal.categories as Record<string, string>;
---
<section class="bg-gradient-to-b from-[color:var(--color-crema)] to-[color:var(--color-warm-white)]">
  <div class="max-w-6xl mx-auto px-5 lg:px-8 pt-14 pb-12 text-center">
    <div class="kicker">Telegram → Web</div>
    <h1 class="font-display italic text-5xl md:text-7xl text-[color:var(--color-burgundy)] mt-3">{dict.journal.page_title}</h1>
    <p class="mt-5 text-lg text-[color:var(--color-espresso)]/75 max-w-2xl mx-auto">{dict.journal.page_subtitle}</p>
    <p class="mt-3 text-sm text-[color:var(--color-espresso)]/60 max-w-2xl mx-auto">{dict.journal.intro}</p>
  </div>
</section>

<section class="py-12 md:py-16">
  <div class="max-w-6xl mx-auto px-5 lg:px-8">
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {journal.map(entry => {
        const photo = entry.data.photos[0];
        const cat = categories[entry.data.category] ?? entry.data.category;
        const href = localizePath(locale, `/journal/${entry.id}`);
        const dateStr = entry.data.date.slice(0, 10);
        return (
          <a href={href} class="group bg-[color:var(--color-warm-white)] rounded-2xl overflow-hidden border border-[color:var(--color-mist)] hover:shadow-lg hover:border-[color:var(--color-burgundy)]/30 transition">
            {photo ? (
              <div class="aspect-[4/3] bg-[color:var(--color-mist)] overflow-hidden relative">
                <img src={photo} alt={entry.data.title_uk} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                <span class="absolute top-3 left-3 kicker bg-[color:var(--color-warm-white)]/95 text-[color:var(--color-burgundy)] px-2.5 py-1 rounded-full text-[0.6rem]">{cat}</span>
              </div>
            ) : (
              <div class="aspect-[4/3] bg-[color:var(--color-crema)] flex items-center justify-center">
                <span class="font-display italic text-[color:var(--color-burgundy)]/50 text-2xl">{cat}</span>
              </div>
            )}
            <div class="p-4">
              <h3 class="font-display text-lg leading-tight line-clamp-2 min-h-[2.6rem]">{entry.data.title_uk}</h3>
              <time class="text-xs text-[color:var(--color-espresso)]/50 mt-2 block">{dateStr}</time>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
