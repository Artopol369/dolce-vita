---
import { getCollection } from "astro:content";
import { t, type Locale, pickBilingual, localizePath } from "../i18n/ui";
import HeroLogo from "./HeroLogo.astro";
import TelegramCta from "./TelegramCta.astro";
import CardTorte from "./CardTorte.astro";
import business from "../data/business.json";
import testimonials from "../data/testimonials.json";
import orderProcess from "../data/order-process.json";
import faq from "../data/faq.json";

interface Props { locale: Locale }
const { locale } = Astro.props;
const dict = t(locale);

const tortes = (await getCollection("tortes")).sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
const sweets = (await getCollection("sweets")).sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
const journal = (await getCollection("journal")).sort((a, b) => b.data.date.localeCompare(a.data.date));

const featuredTortes = tortes.filter(t => t.data.featured).slice(0, 3);
const recentJournal = journal.slice(0, 6);
const categories = dict.journal.categories as Record<string, string>;

const voices = testimonials.slice(0, 3);
const steps = orderProcess.steps;
const faqItems = faq.slice(0, 5);
const owners = business.owners;
const isUk = locale === "uk";
---

<!-- HERO -->
<section class="bg-gradient-to-br from-[color:var(--color-crema)] to-[color:var(--color-warm-white)]">
  <div class="max-w-5xl mx-auto px-5 lg:px-8 pt-16 pb-20 md:pt-24 md:pb-32 text-center">
    <HeroLogo kicker={dict.hero.kicker} titleTop={dict.hero.title_top} titleBottom={dict.hero.title_bottom} />
    <p class="mt-8 text-lg md:text-xl text-[color:var(--color-espresso)]/80 max-w-2xl mx-auto leading-relaxed">{dict.hero.subtitle}</p>
    <div class="mt-10 flex flex-wrap gap-3 justify-center">
      <TelegramCta label={dict.hero.cta_order} variant="primary" />
      <a href={localizePath(locale, "/tortes")} class="btn btn-ghost">{dict.hero.cta_browse}</a>
    </div>
  </div>
</section>

<!-- INTRO -->
<section class="py-20 md:py-28">
  <div class="max-w-5xl mx-auto px-5 lg:px-8 grid md:grid-cols-[1fr_1.4fr] gap-12 items-start">
    <div>
      <div class="kicker">{dict.home.intro_kicker}</div>
      <h2 class="font-display text-4xl md:text-5xl italic text-[color:var(--color-burgundy)] mt-3 leading-tight">{dict.home.intro_title}</h2>
    </div>
    <p class="text-[1.05rem] leading-relaxed text-[color:var(--color-espresso)]/85">{dict.home.intro_body}</p>
  </div>
</section>

<!-- SERVICES -->
<section class="py-12 md:py-16 bg-[color:var(--color-warm-white)] border-y border-[color:var(--color-mist)]">
  <div class="max-w-6xl mx-auto px-5 lg:px-8">
    <div class="kicker text-center">{dict.home.services_kicker}</div>
    <div class="mt-10 grid md:grid-cols-3 gap-6">
      <a href={localizePath(locale, "/tortes")} class="group bg-[color:var(--color-crema)] rounded-2xl p-7 hover:-translate-y-1 transition border border-transparent hover:border-[color:var(--color-burgundy)]/30">
        <div class="kicker text-[color:var(--color-gold)]">01</div>
        <h3 class="font-display text-3xl mt-3">{dict.home.tortes_title}</h3>
        <p class="mt-3 text-sm text-[color:var(--color-espresso)]/70 leading-relaxed">{dict.home.tortes_body}</p>
        <div class="mt-5 font-medium text-sm text-[color:var(--color-burgundy)] group-hover:translate-x-1 transition">{dict.home.tortes_cta} →</div>
      </a>
      <a href={localizePath(locale, "/sweets")} class="group bg-[color:var(--color-crema)] rounded-2xl p-7 hover:-translate-y-1 transition border border-transparent hover:border-[color:var(--color-burgundy)]/30">
        <div class="kicker text-[color:var(--color-gold)]">02</div>
        <h3 class="font-display text-3xl mt-3">{dict.home.sweets_title}</h3>
        <p class="mt-3 text-sm text-[color:var(--color-espresso)]/70 leading-relaxed">{dict.home.sweets_body}</p>
        <div class="mt-5 font-medium text-sm text-[color:var(--color-burgundy)] group-hover:translate-x-1 transition">{dict.home.sweets_cta} →</div>
      </a>
      <a href={localizePath(locale, "/journal")} class="group bg-[color:var(--color-crema)] rounded-2xl p-7 hover:-translate-y-1 transition border border-transparent hover:border-[color:var(--color-burgundy)]/30">
        <div class="kicker text-[color:var(--color-gold)]">03</div>
        <h3 class="font-display text-3xl mt-3">{dict.home.journal_title}</h3>
        <p class="mt-3 text-sm text-[color:var(--color-espresso)]/70 leading-relaxed">{dict.home.journal_body}</p>
        <div class="mt-5 font-medium text-sm text-[color:var(--color-burgundy)] group-hover:translate-x-1 transition">{dict.home.journal_cta} →</div>
      </a>
    </div>
  </div>
</section>

<!-- FEATURED TORTES -->
{featuredTortes.length > 0 && (
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-5 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <div class="kicker">Signature</div>
          <h2 class="font-display italic text-4xl md:text-5xl text-[color:var(--color-burgundy)] mt-2">{dict.tortes.page_title}</h2>
        </div>
        <a href={localizePath(locale, "/tortes")} class="hidden sm:inline-flex text-sm font-medium text-[color:var(--color-burgundy)] hover:underline underline-offset-4">{dict.home.tortes_cta} →</a>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {featuredTortes.map(item => <CardTorte item={item} locale={locale} collection="tortes" />)}
      </div>
    </div>
  </section>
)}

<!-- ABOUT / OWNERS -->
<section class="py-20 md:py-24">
  <div class="max-w-6xl mx-auto px-5 lg:px-8">
    <div class="kicker text-center">{isUk ? "Хто ми" : "Wer wir sind"}</div>
    <h2 class="font-display italic text-4xl md:text-5xl text-center text-[color:var(--color-burgundy)] mt-2">{isUk ? "Двоє жінок, одна кухня" : "Zwei Frauen, eine Backstube"}</h2>
    <div class="mt-12 grid md:grid-cols-2 gap-8">
      {owners.map(o => (
        <article class="bg-[color:var(--color-crema)] rounded-2xl p-7 border border-transparent hover:border-[color:var(--color-burgundy)]/20 transition">
          <div class="flex items-center gap-4">
            <div class="w-16 h-16 rounded-full bg-[color:var(--color-burgundy)] text-[color:var(--color-warm-white)] flex items-center justify-center font-display italic text-2xl shrink-0">
              {o.name.split(" ").map(s => s[0]).join("").slice(0,2)}
            </div>
            <div>
              <div class="font-display text-2xl text-[color:var(--color-burgundy)]">{o.name}</div>
              <div class="kicker text-[0.65rem] mt-1">{isUk ? o.role_uk : o.role_de}</div>
            </div>
          </div>
          <p class="mt-5 text-[0.95rem] leading-relaxed text-[color:var(--color-espresso)]/85">
            {isUk ? o.bio_uk : o.bio_de}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ORDER PROCESS -->
<section class="py-20 md:py-24 bg-[color:var(--color-warm-white)] border-y border-[color:var(--color-mist)]">
  <div class="max-w-6xl mx-auto px-5 lg:px-8">
    <div class="kicker text-center">{isUk ? "Як замовити" : "So bestellt ihr"}</div>
    <h2 class="font-display italic text-4xl md:text-5xl text-center text-[color:var(--color-burgundy)] mt-2">
      {isUk ? orderProcess.intro_uk : orderProcess.intro_de}
    </h2>
    <ol class="mt-12 grid sm:grid-cols-2 lg:grid-cols-5 gap-5">
      {steps.map(s => (
        <li class="bg-[color:var(--color-crema)] rounded-2xl p-5">
          <div class="font-display italic text-[color:var(--color-gold)] text-4xl leading-none">{s.n.toString().padStart(2, "0")}</div>
          <h3 class="font-display text-xl mt-3 text-[color:var(--color-burgundy)]">{isUk ? s.title_uk : s.title_de}</h3>
          <p class="mt-2 text-sm text-[color:var(--color-espresso)]/75 leading-relaxed">{isUk ? s.body_uk : s.body_de}</p>
        </li>
      ))}
    </ol>
    <div class="mt-10 text-center">
      <a href={orderProcess.cta_link} target="_blank" rel="noopener" class="btn btn-primary">
        {isUk ? orderProcess.cta_uk : orderProcess.cta_de}
      </a>
    </div>
  </div>
</section>

<!-- VOICES -->
<section class="py-20 md:py-24">
  <div class="max-w-5xl mx-auto px-5 lg:px-8">
    <div class="kicker text-center">{dict.home.voices_kicker}</div>
    <h2 class="font-display italic text-4xl md:text-5xl text-center text-[color:var(--color-burgundy)] mt-2">{dict.home.voices_title}</h2>
    <div class="mt-12 grid md:grid-cols-3 gap-6">
      {voices.map(v => (
        <figure class="bg-[color:var(--color-crema)] rounded-2xl p-6 relative">
          <div class="font-display italic text-[color:var(--color-burgundy)]/20 text-6xl absolute top-2 left-4 leading-none">"</div>
          <blockquote class="text-[0.95rem] leading-relaxed text-[color:var(--color-espresso)]/85 relative">
            {isUk ? v.text_uk : v.text_de}
          </blockquote>
          <figcaption class="mt-5 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-[color:var(--color-burgundy)] text-[color:var(--color-warm-white)] flex items-center justify-center font-display italic text-sm">
              {v.author.split(" ").map(s => s[0]).join("").slice(0,2)}
            </span>
            <div class="text-xs text-[color:var(--color-espresso)]/70 leading-tight">
              <div>{v.author}</div>
              <div class="text-[color:var(--color-espresso)]/50">{v.city} · {v.date.slice(0,7)}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-20 md:py-24 bg-[color:var(--color-warm-white)] border-y border-[color:var(--color-mist)]">
  <div class="max-w-3xl mx-auto px-5 lg:px-8">
    <div class="kicker text-center">FAQ</div>
    <h2 class="font-display italic text-4xl md:text-5xl text-center text-[color:var(--color-burgundy)] mt-2">{isUk ? "Часті питання" : "Häufige Fragen"}</h2>
    <div class="mt-10 divide-y divide-[color:var(--color-mist)] border-y border-[color:var(--color-mist)]">
      {faqItems.map(item => (
        <details class="group py-5">
          <summary class="cursor-pointer list-none flex items-start justify-between gap-4">
            <span class="font-medium text-[1.02rem] text-[color:var(--color-espresso)]">{isUk ? item.q_uk : item.q_de}</span>
            <span class="text-[color:var(--color-burgundy)] font-display italic text-2xl leading-none shrink-0 group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="mt-3 text-[0.95rem] leading-relaxed text-[color:var(--color-espresso)]/80">{isUk ? item.a_uk : item.a_de}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- RECENT JOURNAL -->
{recentJournal.length > 0 && (
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-5 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <div class="kicker">{dict.home.journal_title}</div>
          <h2 class="font-display italic text-4xl md:text-5xl text-[color:var(--color-burgundy)] mt-2">{locale === "uk" ? "Свіже з кухні" : "Frisch aus der Backstube"}</h2>
        </div>
        <a href={localizePath(locale, "/journal")} class="hidden sm:inline-flex text-sm font-medium text-[color:var(--color-burgundy)] hover:underline underline-offset-4">{dict.home.journal_cta} →</a>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-5">
        {recentJournal.map(entry => {
          const photo = entry.data.photos[0];
          const cat = categories[entry.data.category] ?? entry.data.category;
          const href = localizePath(locale, `/journal/${entry.id}`);
          return (
            <a href={href} class="group bg-[color:var(--color-warm-white)] rounded-2xl overflow-hidden border border-[color:var(--color-mist)] hover:shadow-lg transition">
              {photo && <div class="aspect-[4/3] bg-[color:var(--color-mist)] overflow-hidden">
                <img src={photo} alt={entry.data.title_uk} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>}
              <div class="p-4">
                <div class="kicker text-[0.6rem] text-[color:var(--color-burgundy)]">{cat}</div>
                <h3 class="font-display text-lg mt-1.5 line-clamp-2">{entry.data.title_uk}</h3>
                <time class="text-xs text-[color:var(--color-espresso)]/50 mt-2 block">{entry.data.date.slice(0,10)}</time>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
)}

<!-- CONTACT -->
<section class="py-20 md:py-28 bg-[color:var(--color-burgundy)] text-[color:var(--color-warm-white)]">
  <div class="max-w-4xl mx-auto px-5 lg:px-8 text-center">
    <div class="kicker text-[color:var(--color-gold)]">{dict.home.contact_kicker}</div>
    <h2 class="font-display italic text-4xl md:text-6xl mt-3 leading-tight">{dict.home.contact_title}</h2>
    <p class="mt-5 text-lg text-[color:var(--color-warm-white)]/80">{dict.home.contact_body}</p>
    <div class="mt-10 flex flex-wrap gap-3 justify-center">
      <a href={business.contacts.telegram_url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-[color:var(--color-warm-white)] text-[color:var(--color-burgundy)] px-7 py-3.5 rounded-full font-medium hover:scale-105 transition">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22 3.5L2 11l6 2 2 7 4-4 5 5z" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linejoin="round"/>
        </svg>
        Telegram
      </a>
      <a href={business.contacts.whatsapp_url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-[color:var(--color-warm-white)]/10 border border-[color:var(--color-warm-white)]/40 text-[color:var(--color-warm-white)] px-7 py-3.5 rounded-full font-medium hover:bg-[color:var(--color-warm-white)] hover:text-[color:var(--color-burgundy)] transition">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.6.1-.2.3-.7.9-.8 1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.8-.7-1.4-1.6-1.6-1.9-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.6-1.5-.9-2.1-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.3.2-1.4-.1-.1-.2-.2-.5-.3zM12 2C6.5 2 2 6.5 2 12c0 1.9.5 3.7 1.4 5.3L2 22l4.8-1.4C8.4 21.5 10.1 22 12 22c5.5 0 10-4.5 10-10S17.5 2 12 2z" />
        </svg>
        WhatsApp
      </a>
    </div>
    <div class="mt-12 grid sm:grid-cols-3 gap-6 text-sm text-[color:var(--color-warm-white)]/80 max-w-2xl mx-auto">
      <div>
        <div class="kicker text-[color:var(--color-gold)]">{isUk ? "Адреса" : "Standort"}</div>
        <div class="mt-1.5">{business.address.street}<br />{business.address.zip} {business.address.city}</div>
      </div>
      <div>
        <div class="kicker text-[color:var(--color-gold)]">{isUk ? "Години" : "Öffnungszeiten"}</div>
        <div class="mt-1.5">
          {business.hours.map(h => (
            <div>
              <span class="font-medium">{isUk ? h.day_uk : h.day_de}</span>
              {" "}
              {h.open ? `${h.open}–${h.close}` : (isUk ? "вихідний" : "geschl.")}
            </div>
          ))}
        </div>
      </div>
      <div>
        <div class="kicker text-[color:var(--color-gold)]">{isUk ? "Передзамовлення" : "Vorbestellung"}</div>
        <div class="mt-1.5">
          {isUk ? `мін. ${business.lead_time.standard_days} дні` : `min. ${business.lead_time.standard_days} Tage`}
          <br />via Telegram
        </div>
      </div>
    </div>
  </div>
</section>
