---
import { t, localizePath, type Locale } from "../i18n/ui";
interface Props { locale: Locale }
const { locale } = Astro.props;
const dict = t(locale);
---
<footer class="mt-24 border-t border-[color:var(--color-mist)] bg-[color:var(--color-warm-white)]">
  <div class="max-w-6xl mx-auto px-5 lg:px-8 py-12 grid md:grid-cols-3 gap-10">
    <div>
      <div class="font-display italic text-2xl text-[color:var(--color-burgundy)]">la dolce <span class="font-semibold not-italic">Gera</span></div>
      <p class="kicker mt-2">Caffè · Dolci · Gera</p>
      <p class="mt-4 text-sm leading-relaxed text-[color:var(--color-espresso)]/80">{dict.site_tagline}</p>
    </div>
    <div>
      <h4 class="kicker">{dict.home.contact_kicker}</h4>
      <address class="mt-3 not-italic text-[0.95rem] leading-relaxed">
        {dict.footer.address_line}<br />
        <a href="https://t.me/la_dolce_gera" class="underline decoration-[color:var(--color-burgundy)]/40 underline-offset-4 hover:text-[color:var(--color-burgundy)]">{dict.footer.contact_line}</a>
      </address>
    </div>
    <div>
      <h4 class="kicker">Legal</h4>
      <ul class="mt-3 space-y-2 text-[0.95rem]">
        <li><a href={localizePath(locale, "/impressum")} class="hover:text-[color:var(--color-burgundy)]">{dict.nav.impressum}</a></li>
        <li><a href={localizePath(locale, "/datenschutz")} class="hover:text-[color:var(--color-burgundy)]">{dict.nav.datenschutz}</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-[color:var(--color-mist)]">
    <div class="max-w-6xl mx-auto px-5 lg:px-8 py-5 text-xs text-[color:var(--color-espresso)]/60 flex justify-between">
      <span>{dict.footer.copyright}</span>
      <span>Made with care.</span>
    </div>
  </div>
</footer>
