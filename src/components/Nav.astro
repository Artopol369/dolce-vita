---
import { t, alternateHref, localizePath, type Locale } from "../i18n/ui";
interface Props { locale: Locale; pathname: string }
const { locale, pathname } = Astro.props;
const dict = t(locale);
const altHref = alternateHref(locale, pathname);
const altLabel = locale === "de" ? "UK" : "DE";

const items = [
  { href: localizePath(locale, "/tortes"),  label: dict.nav.tortes },
  { href: localizePath(locale, "/sweets"),  label: dict.nav.sweets },
  { href: localizePath(locale, "/journal"), label: dict.nav.journal }
];
---
<header class="sticky top-0 z-40 backdrop-blur bg-[color:var(--color-crema)]/85 border-b border-[color:var(--color-mist)]">
  <div class="max-w-6xl mx-auto px-5 lg:px-8 h-16 flex items-center justify-between">
    <a href={localizePath(locale, "/")} class="font-display italic text-[color:var(--color-burgundy)] text-2xl tracking-tight">
      la dolce <span class="font-semibold not-italic tracking-normal">Gera</span>
    </a>
    <nav class="hidden md:flex items-center gap-8 text-[0.95rem]">
      {items.map(it => (
        <a href={it.href} class="hover:text-[color:var(--color-burgundy)] transition">{it.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a href={altHref} class="text-xs tracking-widest uppercase border border-[color:var(--color-espresso)]/30 rounded-full px-3 py-1.5 hover:bg-[color:var(--color-espresso)] hover:text-[color:var(--color-warm-white)] transition">
        {altLabel}
      </a>
      <a href="https://t.me/la_dolce_gera" target="_blank" rel="noopener" class="btn btn-primary hidden sm:inline-flex text-sm">
        Telegram
      </a>
    </div>
  </div>
  <div class="md:hidden border-t border-[color:var(--color-mist)]">
    <nav class="max-w-6xl mx-auto px-5 py-2 flex gap-5 overflow-x-auto text-sm">
      {items.map(it => <a href={it.href} class="whitespace-nowrap">{it.label}</a>)}
    </nav>
  </div>
</header>
