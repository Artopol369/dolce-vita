---
interface Props { title: string; kicker?: string }
const { title, kicker } = Astro.props;
---
<article class="max-w-3xl mx-auto px-5 lg:px-8 py-14 md:py-20">
  {kicker && <div class="kicker text-[color:var(--color-burgundy)]">{kicker}</div>}
  <h1 class="font-display italic text-4xl md:text-5xl text-[color:var(--color-burgundy)] mt-2 leading-tight">{title}</h1>
  <div class="mt-10 space-y-6 leading-relaxed text-[color:var(--color-espresso)]/90 text-[0.97rem]">
    <slot />
  </div>
</article>
<style is:global>
  article h2 { font-family: var(--font-display); font-style: italic; color: var(--color-burgundy); font-size: 1.75rem; margin-top: 2.25rem; margin-bottom: 0.6rem; line-height: 1.2; }
  article h3 { font-family: var(--font-display); color: var(--color-espresso); font-size: 1.25rem; margin-top: 1.5rem; margin-bottom: 0.4rem; }
  article p { margin-bottom: 0.8rem; }
  article ul { list-style: disc; padding-left: 1.25rem; margin-bottom: 0.8rem; }
  article ul li { margin-bottom: 0.25rem; }
  article a { color: var(--color-burgundy); text-decoration: underline; text-underline-offset: 3px; }
  article .placeholder-tag { display: inline-block; padding: 1px 6px; border-radius: 4px; background: #fef3c7; color: #78350f; font-size: 0.78em; font-weight: 500; border: 1px dashed #d97706; }
</style>
